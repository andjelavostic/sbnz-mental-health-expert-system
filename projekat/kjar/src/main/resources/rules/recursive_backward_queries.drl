rule "Evidence - Generic Low Risk"
when
    EmotionalFeatures(ESI < 0.3, NAI < 0.3, EVI < 0.3, LCI < 0.3)
    SleepFeatures(FI < 0.3, SFI < 0.3)
    CognitiveFeatures(CLI < 0.3, MFS < 0.3, DLI < 0.3)
    SocialFeatures(SWI < 0.3, IDI < 0.3, SAD < 0.3)
    EnvironmentalFeatures(externalStressIndex < 0.3, chronicStressExposure < 0.3)
then
    insert(new EvidenceLink("LOW_RISK", "lowEmotionalFeatures"));
    insert(new EvidenceLink("LOW_RISK", "lowSleepFeatures"));
    insert(new EvidenceLink("LOW_RISK", "lowCognitiveFeatures"));
    insert(new EvidenceLink("LOW_RISK", "lowSocialFeatures"));
    insert(new EvidenceLink("LOW_RISK", "lowEnvironmentalFeatures"));
end

rule "Evidence - Low Emotional Tension"
when
    EmotionalFeatures(ESI >= 0.2 && ESI < 0.3, NAI < 0.3, EVI < 0.3, LCI < 0.3)
then
    insert(new EvidenceLink("LOW_EMOTIONAL_TENSION", "ESI"));
    insert(new EvidenceLink("LOW_EMOTIONAL_TENSION", "NAI"));
    insert(new EvidenceLink("LOW_EMOTIONAL_TENSION", "EVI"));
    insert(new EvidenceLink("LOW_EMOTIONAL_TENSION", "LCI"));
end

rule "Evidence - Low Mood Vulnerability"
when
    EmotionalFeatures(NAI >= 0.2 && NAI < 0.3, ESI < 0.3, EVI < 0.3, LCI < 0.3)
then
    insert(new EvidenceLink("LOW_MOOD_VULNERABILITY", "NAI"));
    insert(new EvidenceLink("LOW_MOOD_VULNERABILITY", "ESI"));
    insert(new EvidenceLink("LOW_MOOD_VULNERABILITY", "EVI"));
    insert(new EvidenceLink("LOW_MOOD_VULNERABILITY", "LCI"));
end

