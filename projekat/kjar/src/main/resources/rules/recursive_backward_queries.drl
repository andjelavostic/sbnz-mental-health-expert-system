package rules;

import com.ftn.sbnz.model.evidence.EvidenceLink;
import com.ftn.sbnz.model.features.*;
import com.ftn.sbnz.model.risks.*;
import com.ftn.sbnz.model.events.*;
import com.ftn.sbnz.model.patterns.*;

query "supportsEvidence"(String $goal, String $evidence, Integer $depth)
    EvidenceLink(goal == $goal, evidence == $evidence)
or
    eval($depth.intValue() > 0)
    EvidenceLink(goal == $goal, $middle : evidence)
    $nextDepth : Integer() from Integer.valueOf($depth.intValue() - 1)
    supportsEvidence($middle, $evidence, $nextDepth;)
end

query "whyLowRisk"
    supportsEvidence("LOW_RISK", "lowEmotionalFeatures", 4;)
    supportsEvidence("LOW_RISK", "lowSleepFeatures", 4;)
    supportsEvidence("LOW_RISK", "lowCognitiveFeatures", 4;)
    supportsEvidence("LOW_RISK", "lowSocialFeatures", 4;)
    supportsEvidence("LOW_RISK", "lowEnvironmentalFeatures", 4;)
end

