package rules;
import com.ftn.sbnz.model.patterns.*;
import com.ftn.sbnz.model.decision.*;
import java.util.List;

rule "Early Burnout Final Decision"
when
    BurnoutPattern( earlyBurnout == true, $score : score )
then
    insert(new FinalDecision(
        FinalState.EARLY_BURNOUT_PATTERN,
        Severity.MODERATE,
        "Povisen stres los san i mentalno opterecenje",
        "Smanjiti opterecenje povecati odmor i stabilizovati rutinu sna",
        List.of("EarlyBurnoutPattern"),
        $score
    ));
end

rule "Burnout Syndrome Final Decision"
when
    BurnoutPattern( burnoutSyndrome == true, $score : score )
then
    insert(new FinalDecision(
        FinalState.BURNOUT_SYNDROME,
        Severity.HIGH,
        "Emocionalna i fizicka iscrpljenost uz mentalni overload",
        "Redukovati opterecenje i obezbediti oporavak",
        List.of("BurnoutSyndrome"),
        $score
    ));
end

rule "Severe Burnout Final Decision"
when
    BurnoutPattern( severeBurnoutState == true, $score : score )
then
    insert(new FinalDecision(
        FinalState.SEVERE_BURNOUT_STATE,
        Severity.CRITICAL,
        "Multisistemska iscrpljenost i hronicno pogorsanje",
        "Hitna psiholoska intervencija i potpuni odmor",
        List.of("SevereBurnoutState"),
        $score
    ));
end

