rule "Stress Progression Risk"
when
    TemporalFeatures( $dr : DR, $evl : EVL, DR >= 0.6, EVL >= 0.6 )
then
    TemporalRisks risk = new TemporalRisks();
    risk.setStressProgressionRisk(true);
    risk.setScore(($dr + $evl) / 2.0);
    insert(risk);
end

rule "Chronic Deterioration Risk"
when
    TemporalFeatures( $sps : SPS, $dr : DR, SPS >= 0.6, DR >= 0.6 )
then
    TemporalRisks risk = new TemporalRisks();
    risk.setDeteriorationRisk(true);
    risk.setScore(($sps + $dr) / 2.0);
    insert(risk);
end


