package rules;
import com.ftn.sbnz.model.risks.*;
import com.ftn.sbnz.model.patterns.*;
import com.ftn.sbnz.model.events.*;

declare StressEscalationEvent @role(event) end
declare BurnoutEmergenceEvent @role(event) end
declare EmotionalVolatilityBurstEvent @role(event) end
declare CognitiveDegradationEvent @role(event) end
declare SocialCollapseEvent @role(event) end
declare CrisisBuildUpEvent @role(event) end

//ANXIETY PATTERNS
rule "Early Burnout Pattern"
when
    EmotionalRisks( emotionalStressRisk == true, $s1 : score)
    PhysicalRisks( sleepDisturbanceRisk == true, $s2 : score)
    CognitiveRisks( cognitiveStrainRisk == true, $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setEarlyBurnout(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
rule "Burnout Syndrome Pattern"
when
    $er : EmotionalRisks(emotionalOverloadRisk == true, $s1 : score)
    $pr : PhysicalRisks(sleepDeprivationRisk == true, $s2 : score)
    $cr : CognitiveRisks(cognitiveOverloadRisk == true, $s3 : score)
    $eventList : List() from collect(BurnoutEmergenceEvent())
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setBurnoutSyndrome(true);
    double riskScore = ($s1 + $s2 + $s3) / 3.0;
    BurnoutEmergenceEvent $e = ($eventList.isEmpty()) ? null : (BurnoutEmergenceEvent)$eventList.get(0);
    double finalScore = ($e != null) ? ( ( ( ($s1+$s2+$s3)/3.0 ) * 0.5 ) + ( $e.getScore() * 0.5 ) ) : riskScore;
    bp.setScore(finalScore);
    insert(bp);
end
rule "Severe Burnout Pattern"
when
    PhysicalRisks( exhaustionRisk == true,  $s1 : score)
    SocialRisks( socialIsolationRisk == true,  $s2 : score)
    TemporalRisks( deteriorationRisk == true,  $s3 : score)
    EmotionalRisks( emotionalInstabilityRisk == true,  $s4 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setSevereBurnoutState(true);
    bp.setScore(($s1 + $s2 + $s3 + $s4) / 4.0);
    insert(bp);
end
rule "Severe Burnout Pattern - CEP Based"
when
    $e1 : BurnoutEmergenceEvent($s1 : score)
    $e2 : SocialCollapseEvent($s2 : score)
    $tr : TemporalRisks(emotionalInstabilityTemporalRisk == true, $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setSevereBurnoutState(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
rule "Occupational Exhaustion Pattern"
when
    EnvironmentalRisks( highExternalStressRisk == true, $s1 : score)
    PhysicalRisks( physicalFatigueRisk == true, $s2 : score)
    BurnoutPattern( burnoutSyndrome == true, $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setOccupationalExhaustion(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
//DEPRESSIVE PATTERNS
rule "Depressive Pattern"
when
    SocialRisks( socialIsolationRisk == true,  $s1 : score)
    EmotionalRisks( emotionalStressRisk == true,  $s2 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setDepressivePattern(true);
    dp.setScore(($s1 + $s2) / 2.0);
    insert(dp);
end
rule "Emotional Numbness State - Cognitive + Emotional"
when
    EmotionalRisks( emotionalInstabilityRisk == true, $s1 : score)
    CognitiveRisks( cognitiveOverloadRisk == true, $s2 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setEmotionalNumbnessState(true);
    dp.setScore(($s1 + $s2) / 2.0);
    insert(dp);
end
rule "Emotional Numbness State - CEP Based"
when
    $e1 : EmotionalVolatilityBurstEvent($s1 : score)
    $e2 : CognitiveDegradationEvent($s2 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setEmotionalNumbnessState(true);
    dp.setScore(($s1 + $s2) / 2.0);
    insert(dp);
end
rule "Motivational Collapse"
when
    SocialRisks( behavioralWithdrawalRisk == true, $s1 : score)
    CognitiveRisks( mentalFatigueRisk == true, $s2 : score)
    $e : SocialCollapseEvent($es : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setMotivationalCollapse(true);
    dp.setScore(($s1 + $s2 + $es) / 3.0);
    insert(dp);
end
rule "Severe Depressive Risk Pattern"
when
    TemporalRisks( deteriorationRisk == true, $s1 : score)
    SocialRisks( socialIsolationRisk == true, $s2 : score)
    EmotionalRisks( emotionalOverloadRisk == true, $s3 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setSevereDepressiveRisk(true);
    dp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(dp);
end
rule "Severe Depressive Risk Pattern - CEP Based"
when
    $e1 : SocialCollapseEvent($s1 : score)
    $e2 : EmotionalVolatilityBurstEvent($s2 : score)
    $e3 : CrisisBuildUpEvent($s3 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setSevereDepressiveRisk(true);
    dp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(dp);
end
//ANXIETY PATTERNS
