//CRITICAL PATTERNS
rule "Severe psychological deterioration - full system"
when
    TemporalRisks( chronicDeteriorationRisk == true )
    EmotionalRisks( emotionalInstabilityRisk == true )
    CognitiveRisks( cognitiveOverloadRisk == true )
    SocialRisks( socialIsolationRisk == true )
then
    CriticalPattern p = new CriticalPattern();
    p.setSeverePsychologicalDeterioration(true);
    insert(p);
end
//CEP
rule "Emotional collapse risk"
when
    EmotionalRisks( severeEmotionalCrisisRisk == true )
    EmotionalEvents( emotionalVolatilityBurst == true )
    TemporalEvents( crisisBuildUpEvent == true )
then
    CriticalPattern p = new CriticalPattern();
    p.setEmotionalCollapseRisk(true);
    insert(p);
end
rule "Self-harm risk pattern"
when
    DepressionPattern( severeDepressiveRiskPattern == true )
    CriticalPattern( severePsychologicalDeterioration == true )
    CriticalPattern( emotionalCollapseRisk == true )
then
    CriticalPattern p = new CriticalPattern();
    p.setSelfHarmRisk(true);
    insert(p);
end
rule "Crisis intervention recommended"
when
    PhysicalRisks( exhaustionSyndromeRisk == true )
    EmotionalRisks( severeEmotionalCrisisRisk == true )
then
    CriticalPattern p = new CriticalPattern();
    p.setCrisisInterventionRecommended(true);
    insert(p);
end
