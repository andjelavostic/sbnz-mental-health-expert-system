    EmotionalRisks( emotionalInstabilityRisk == true, $s2 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setAnxietyEscalation(true);
    ap.setScore(($s1 + $s2) / 2.0);
    insert(ap);
end
