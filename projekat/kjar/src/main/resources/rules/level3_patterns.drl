end
//CRITICAL PATTERNS
rule "Severe psychological deterioration - full system"
when
    TemporalRisks( deteriorationRisk == true, $s1 : score)
    EmotionalRisks( emotionalInstabilityRisk == true, $s2 : score)
    CognitiveRisks( cognitiveOverloadRisk == true, $s3 : score)
    SocialRisks( socialIsolationRisk == true, $s4 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setSeverePsychologicalDeterioration(true);
    p.setScore(($s1 + $s2 + $s3 + $s4) / 4.0);
    insert(p);
end
