//COGNITIVE PATTERN
rule "Mental fatigue syndrome - feature based"
when
    CognitiveRisks( cognitiveOverloadRisk == true )
    PhysicalRisks( sleepDeprivationRisk == true )
    EmotionalRisks( emotionalStressRisk == true )
then
    CognitivePattern p = new CognitivePattern();
    p.setMentalFatigueSyndrome(true);
    insert(p);
end
//CEP
rule "Concentration decline pattern"
when
    CognitiveEvents( cognitiveDegradationEvent == true )
    CognitiveRisks( decisionImpairmentRisk == true )
then
    CognitivePattern p = new CognitivePattern();
    p.setConcentrationDecline(true);
    insert(p);
end
rule "Decision collapse state - risk based"
when
    CognitiveRisks( decisionImpairmentRisk == true )
    CognitiveRisks( cognitiveOverloadRisk == true )
    EmotionalRisks( emotionalInstabilityRisk == true )
then
    CognitivePattern p = new CognitivePattern();
    p.setDecisionFatigue(true);
    insert(p);
end
