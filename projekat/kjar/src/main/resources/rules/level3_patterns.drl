    $e1 : StressEscalationEvent($s1 : score)
    $e2 : EmotionalVolatilityBurstEvent($s2 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setAnxietyEscalation(true);
    ap.setScore(($s1 + $s2) / 2.0);
    insert(ap);
end
rule "Panic Attack Pattern"
when
    EmotionalRisks( emotionalOverloadRisk == true, $s1 : score)
    TemporalRisks( escalationRisk == true, $s2 : score)
    PhysicalRisks( sleepDeprivationRisk == true, $s3 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setPanicAttack(true);
    ap.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(ap);
end
rule "Panic Attack Pattern - CEP Based"
salience 200 // Visoki prioritet za hitno stanje
when
    $e1 : StressEscalationEvent($s1 : score)
    $e2 : EmotionalVolatilityBurstEvent($s2 : score)
    $tr : TemporalRisks(escalationRisk == true, $s3 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setPanicAttack(true);
    ap.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(ap);
end
rule "Generalized Anxiety Tendency"
when
    EmotionalRisks(emotionalStressRisk == true, $s1 : score)
