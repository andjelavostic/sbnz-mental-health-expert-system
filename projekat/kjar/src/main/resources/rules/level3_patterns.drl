//CRITICAL PATTERNS
rule "Severe Psychological Deterioration - CEP Based"
salience 500 
when
    $e1 : CrisisBuildUpEvent($s1 : score)
    $e2 : CognitiveDegradationEvent($s2 : score)
    $e3 : SocialCollapseEvent($s3 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setSeverePsychologicalDeterioration(true);
    p.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(p);
end
rule "Emotional collapse risk"
when
    EmotionalRisks( emotionalCrisisRisk == true, $s1: score)
    $e1 : EmotionalVolatilityBurstEvent($es1 : score)
    $e2 : CrisisBuildUpEvent($es2 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setEmotionalCollapseRisk(true);
    p.setScore(($s1 + $es1 + $es2) / 3.0);
    insert(p);
end
rule "Self-harm risk pattern"
when
    DepressivePattern( severeDepressiveRisk == true, $s1 : score)
    CriticalPattern( severePsychologicalDeterioration == true, $s2 : score)
    CriticalPattern( emotionalCollapseRisk == true, $s3 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setSelfHarmRisk(true);
    p.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(p);
end
rule "Crisis intervention recommended"
when
    PhysicalRisks( exhaustionRisk == true, $s1 : score)
    EmotionalRisks( emotionalCrisisRisk == true, $s2 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setCrisisInterventionRecommended(true);
    p.setScore(($s1 + $s2) / 2.0);
    insert(p);
end
rule "Crisis Intervention Recommended - CEP Based"
salience 1000
when
    $e1 : CrisisBuildUpEvent($s1 : score)
    $e2 : CriticalPattern(emotionalCollapseRisk == true, $s2 : score) 
    $p : CriticalPattern(severePsychologicalDeterioration == true, $s3 : score)
then
    CriticalPattern p = new CriticalPattern();
    p.setCrisisInterventionRecommended(true);
    p.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(p);
end