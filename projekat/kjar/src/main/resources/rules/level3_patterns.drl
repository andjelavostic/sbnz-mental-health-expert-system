//ANXIETY PATTERNS
rule "Early Burnout Pattern"
when
    EmotionalRisks( emotionalStressRisk == true )
    PhysicalRisks( sleepDisturbanceRisk == true )
    CognitiveRisks( cognitiveStrainRisk == true )
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setEarlyBurnout(true);
    insert(bp);
end
rule "Burnout Syndrome Pattern"
when
    EmotionalRisks( emotionalOverloadRisk == true )
    PhysicalRisks( sleepDeprivationRisk == true )
    CognitiveRisks( cognitiveOverloadRisk == true )
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setBurnoutSyndrome(true);
    insert(bp);
end
//CEP??
rule "Severe Burnout Pattern"
when
    PhysicalRisks( exhaustionSyndromeRisk == true )
    SocialRisks( socialIsolationRisk == true )
    TemporalRisks( chronicDeteriorationRisk == true )
    EmotionalRisks( emotionalInstabilityRisk == true )
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setSevereBurnoutState(true);
    insert(bp);
end
//CEP ZA SEVERE
rule "Occupational Exhaustion Pattern"
when
    EnvironmentalRisks( highExternalStressRisk == true )
    PhysicalRisks( physicalFatigueRisk == true )
    BurnoutPattern( burnoutSyndrome == true )
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setOccupationalExhaustion(true);
    insert(bp);
end
//DEPRESSIVE PATTERNS
rule "Depressive Pattern"
when
    SocialRisks( socialIsolationRisk == true )
    EmotionalRisks( emotionalStressRisk == true )
then
    DepressionPattern dp = new DepressionPattern();
    dp.setDepressivePattern(true);
    insert(dp);
end
rule "Emotional Numbness State - Cognitive + Emotional"
when
    EmotionalRisks( emotionalInstabilityRisk == true )
    CognitiveRisks( cognitiveOverloadRisk == true )
then
    DepressionPattern dp = new DepressionPattern();
    dp.setEmotionalNumbnessState(true);
    insert(dp);
end
//CEP ZA NUMBNES
rule "Motivational Collapse"
when
    SocialRisks( behavioralWithdrawalRisk == true )
    CognitiveRisks( mentalFatigueRisk == true )
    SocialCollapseEvent()
then
    DepressionPattern dp = new DepressionPattern();
    dp.setMotivationalCollapse(true);
    insert(dp);
end
rule "Severe Depressive Risk Pattern"
when
    TemporalRisks( chronicDeteriorationRisk == true )
    SocialRisks( socialIsolationRisk == true )
    EmotionalRisks( emotionalOverloadRisk == true )
then
    DepressionPattern dp = new DepressionPattern();
    dp.setSevereDepressiveRisk(true);
    insert(dp);
end
