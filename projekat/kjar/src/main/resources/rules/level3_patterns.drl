    EmotionalRisks( emotionalStressRisk == true, $s3 : score)
then
    CognitivePattern p = new CognitivePattern();
    p.setMentalFatigueSyndrome(true);
    p.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(p);
end
