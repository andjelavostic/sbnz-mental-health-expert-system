rule "Social isolation progression"
when
    //SocialEvents( socialCollapseEvent == true ) EVENT
    TemporalRisks( deteriorationRisk == true, $s1 : score)
then
    SocialPattern p = new SocialPattern();
    p.setSocialIsolationProgression(true);
