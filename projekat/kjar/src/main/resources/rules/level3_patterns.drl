//ANXIETY PATTERNS
rule "Anxiety Pattern"
when
    EmotionalRisks( emotionalStressRisk == true, $s1 : score)
    CognitiveRisks( cognitiveStrainRisk == true, $s2 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setAnxietyRisk(true);
    ap.setScore(($s1 + $s2) / 2.0);
    insert(ap);
end
