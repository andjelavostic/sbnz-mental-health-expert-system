package rules;
import com.ftn.sbnz.model.risks.*;
import com.ftn.sbnz.model.patterns.*;
//ANXIETY PATTERNS
rule "Early Burnout Pattern"
when
    EmotionalRisks( emotionalStressRisk == true, $s1 : score)
    PhysicalRisks( sleepDisturbanceRisk == true, $s2 : score)
    CognitiveRisks( cognitiveStrainRisk == true, $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setEarlyBurnout(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
rule "Burnout Syndrome Pattern"
when
    EmotionalRisks( emotionalOverloadRisk == true,  $s1 : score)
    PhysicalRisks( sleepDeprivationRisk == true,  $s2 : score)
    CognitiveRisks( cognitiveOverloadRisk == true,  $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setBurnoutSyndrome(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
//CEP??
rule "Severe Burnout Pattern"
when
    PhysicalRisks( exhaustionRisk == true,  $s1 : score)
    SocialRisks( socialIsolationRisk == true,  $s2 : score)
    TemporalRisks( deteriorationRisk == true,  $s3 : score)
    EmotionalRisks( emotionalInstabilityRisk == true,  $s4 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setSevereBurnoutState(true);
    bp.setScore(($s1 + $s2 + $s3 + $s4) / 4.0);
    insert(bp);
end
//CEP ZA SEVERE
rule "Occupational Exhaustion Pattern"
when
    EnvironmentalRisks( highExternalStressRisk == true, $s1 : score)
    PhysicalRisks( physicalFatigueRisk == true, $s2 : score)
    BurnoutPattern( burnoutSyndrome == true, $s3 : score)
then
    BurnoutPattern bp = new BurnoutPattern();
    bp.setOccupationalExhaustion(true);
    bp.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(bp);
end
//DEPRESSIVE PATTERNS
rule "Depressive Pattern"
when
    SocialRisks( socialIsolationRisk == true,  $s1 : score)
    EmotionalRisks( emotionalStressRisk == true,  $s2 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setDepressivePattern(true);
    dp.setScore(($s1 + $s2) / 2.0);
    insert(dp);
end
rule "Emotional Numbness State - Cognitive + Emotional"
when
    EmotionalRisks( emotionalInstabilityRisk == true, $s1 : score)
    CognitiveRisks( cognitiveOverloadRisk == true, $s2 : score)
then
    DepressivePattern dp = new DepressivePattern();
    dp.setEmotionalNumbnessState(true);
    dp.setScore(($s1 + $s2) / 2.0);
    insert(dp);
end
