    $e : StressEscalationEvent($s3 : score)
then
    AnxietyPattern ap = new AnxietyPattern();
    ap.setGeneralizedAnxiety(true);
    ap.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(ap);
end
//COGNITIVE PATTERN
rule "Mental fatigue syndrome - feature based"
when
    CognitiveRisks( cognitiveOverloadRisk == true, $s1 : score)
    PhysicalRisks( sleepDeprivationRisk == true, $s2 : score)
    EmotionalRisks( emotionalStressRisk == true, $s3 : score)
then
    CognitivePattern p = new CognitivePattern();
    p.setMentalFatigueSyndrome(true);
    p.setScore(($s1 + $s2 + $s3) / 3.0);
    insert(p);
end
rule "Mental Fatigue Syndrome - CEP Based"
when
    $e1 : CognitiveDegradationEvent($s1 : score)
    $e2 : BurnoutEmergenceEvent($s2 : score)
then
    CognitivePattern p = new CognitivePattern();
    p.setMentalFatigueSyndrome(true);
    p.setScore(($s1 + $s2) / 2.0);
    insert(p);
end
rule "Concentration decline pattern"
when
    $e : CognitiveDegradationEvent($es : score) // CEP potvrda
    CognitiveRisks( decisionImpairmentRisk == true, $s2:score )
then
    CognitivePattern p = new CognitivePattern();
    p.setConcentrationDecline(true);
    p.setScore(($es + $s2) / 2.0);
    insert(p);
end
